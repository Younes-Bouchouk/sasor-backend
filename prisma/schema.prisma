generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  pseudo         String   @unique
  sexe           String
  password       String
  biography      String?
  profilePicture String?  @map("profile_picture")
  birthday       DateTime
  deletedAt      BigInt?  @map("deleted_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organizedEvents     Event[]
  invitationsReceived EventInvitation[]  @relation("InvitationReceiver")
  invitationsSent     EventInvitation[]  @relation("InvitationSender")
  messagesSent        EventMessage[]
  joinedEvents        EventParticipant[]
  followers           Follow[]           @relation("Follower")
  following           Follow[]           @relation("Following")
  subscriptions       UserSubscription[]

  @@map("users")
}

model Follow {
  id          Int      @id @default(autoincrement())
  followerId  String   @map("follower_id")
  followingId String   @map("following_id")
  deletedAt   BigInt?  @map("deleted_at")
  createdAt   DateTime @default(now()) @map("created_at")

  follower  User @relation("Follower", fields: [followerId], references: [id])
  following User @relation("Following", fields: [followingId], references: [id])

  @@unique([followerId, followingId])
  @@map("follows")
}

model Sport {
  id             Int       @id @default(autoincrement())
  name           String
  isHighlighted  Boolean   @default(false) @map("is_highlighted")
  startHighlight DateTime? @map("start_highlight")
  endHighlight   DateTime? @map("end_highlight")
  deletedAt      DateTime? @map("deleted_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  events Event[]

  @@map("sports")
}

model Event {
  id              Int      @id @default(autoincrement())
  userId          String   @map("user_id")
  sportId         Int      @map("sport_id")
  name            String
  description     String?
  image           String?
  location        String
  isPrivate       Boolean  @default(false) @map("is_private")
  maxParticipants Int      @map("max_participants")
  startAt         DateTime @map("start_at")
  endAt           BigInt?  @map("end_at")
  deletedAt       BigInt?  @map("deleted_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  organizer    User               @relation(fields: [userId], references: [id])
  sport        Sport              @relation(fields: [sportId], references: [id])
  invitations  EventInvitation[]
  messages     EventMessage[]
  participants EventParticipant[]

  @@map("events")
}

model EventParticipant {
  id          Int      @id @default(autoincrement())
  userId      String   @map("user_id")
  eventId     Int      @map("event_id")
  canInvite   Boolean  @default(false) @map("can_invite")
  deletedAt   BigInt?  @map("deleted_at")
  updatedAt   BigInt?  @map("updated_at")
  createdAt   DateTime @default(now()) @map("created_at")

  event       Event @relation(fields: [eventId], references: [id])
  participant User  @relation(fields: [userId], references: [id])

  @@unique([userId, eventId])
  @@map("events_participants")
}

model EventMessage {
  id        Int      @id @default(autoincrement())
  userId    String   @map("user_id")
  eventId   Int      @map("event_id")
  message   String
  picture   String?
  deletedAt BigInt?  @map("deleted_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  event  Event @relation(fields: [eventId], references: [id])
  sender User  @relation(fields: [userId], references: [id])

  @@map("events_messages")
}

model EventInvitation {
  id          BigInt    @id @default(autoincrement())
  eventId     Int       @map("event_id")
  invitedById String    @map("invited_by_id")
  userId      String    @map("user_id")
  status      String    @default("PENDING")
  respondedAt DateTime? @map("responded_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  event   Event @relation(fields: [eventId], references: [id])
  invitee User  @relation("InvitationReceiver", fields: [userId], references: [id])
  inviter User  @relation("InvitationSender", fields: [invitedById], references: [id])

  @@unique([eventId, userId])
  @@map("events_invitations")
}

model UserSubscription {
  id        BigInt    @id @default(autoincrement())
  userId    String    @map("user_id")
  type      String
  startAt   DateTime? @map("start_at")
  endAt     DateTime? @map("end_at")
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@map("users_subscriptions")
}
